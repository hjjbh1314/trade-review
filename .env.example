# ─── Trade Review · environment template ───────────────────────────────
# Copy to `.env` and edit. None of these are required to start the app.

# Display name used in the AI coach's system prompts (e.g. "Leo", "ZhangSan").
# Leave blank to fall back to the neutral default ("the trader").
TR_USER_NAME=

# Same name, exposed to the frontend at build time so it shows in the top nav.
# Vite reads `VITE_*` only — so this one is duplicated by design.
VITE_USER_NAME=

# Which AI engine to use:
# - claude: uses your local Claude Code OAuth login, no Anthropic API key needed.
# - deepseek: uses DeepSeek's OpenAI-compatible API.
TR_AI_ENGINE=claude

# Required only when TR_AI_ENGINE=deepseek.
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Optional: iFinD MCP enrichment for A-share snapshots ────────────
# Without this, A-share data still works via akshare. iFinD adds a richer
# natural-language summary that the coach can quote from. Apply for a token
# at https://ft.10jqka.com.cn/ if you have access.
# IFIND_AUTH_TOKEN=
